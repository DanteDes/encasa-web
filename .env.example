# Genera un secret con: openssl rand -base64 32
AUTH_SECRET='tu-secret-aqui'

# URL del frontend en producción (sin trailing slash)
NEXTAUTH_URL=https://tu-proyecto.vercel.app

# Credenciales de Google OAuth
# Obtenerlas en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend API URL (Railway)
# NEXT_PUBLIC_API_URL se usa en el cliente (browser)
# BACKEND_URL se usa en el servidor (Next.js server-side, auth callbacks)
# Ambos deben apuntar a la misma URL de Railway en producción
NEXT_PUBLIC_API_URL=https://tu-proyecto.railway.app
BACKEND_URL=https://tu-proyecto.railway.app
